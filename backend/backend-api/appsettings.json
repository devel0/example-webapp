{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console"],
    "MinimumLevel": {
      "Default": "Verbose",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": ["Console"]
  },    
  "JwtSettings": {
    "Issuer": "https://www.example.com",
    "Audience": "https://www.example.com/app",
    "AccessTokenDurationSeconds": "10", // "1200",
    "RefreshTokenDurationSeconds": "20", // "172800",
    "ClockSkewSeconds": "0"
  },
  "SeedUsers": {
    "Admin": {
      "UserName": "admin"
    }
  },
  "DbLoggingEnabled": true,
  "AllowedHosts": "*"
}
